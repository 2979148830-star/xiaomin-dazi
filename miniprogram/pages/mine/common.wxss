page {
  background: linear-gradient(180deg, #f4f6ff 0%, #f8fbff 48%, #eef8f5 100%);
}

.page-shell {
  padding: 24rpx 24rpx 40rpx;
}

.section-card {
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  background:
    radial-gradient(circle at 10% 0%, rgba(255, 255, 255, 0.72) 0%, rgba(255, 255, 255, 0) 30%),
    linear-gradient(135deg, #f0f4ff 0%, #fbf6ff 56%, #eefbf7 100%);
  border-radius: 30rpx;
  padding: 28rpx;
  box-shadow: 0 16rpx 36rpx rgba(79, 92, 170, 0.12);
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.card-hover {
  opacity: 0.9;
}

.section-kicker {
  font-size: 22rpx;
  color: #5f6bff;
  margin-bottom: 12rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #243140;
}

.section-desc {
  font-size: 24rpx;
  color: #7b8793;
  line-height: 1.6;
  margin-top: 10rpx;
}

.status-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.status-pill.open,
.status-pill.enabled {
  background: #eaf7f2;
  color: #1f8a5b;
}

.status-pill.full {
  background: #fff1f1;
  color: #c65159;
}

.status-pill.pending {
  background: #fff6df;
  color: #9a6421;
}

.status-pill.error {
  background: #fff1f1;
  color: #cf4a52;
}

.primary-btn,
.ghost-btn,
.danger-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  line-height: 1.2;
  padding: 0 28rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  text-align: center;
  box-sizing: border-box;
}

.primary-btn {
  background: linear-gradient(135deg, #5f6bff 0%, #8b5cf6 100%);
  color: #ffffff;
  box-shadow: 0 16rpx 28rpx rgba(95, 107, 255, 0.22);
}

.ghost-btn {
  background: #eef0ff;
  color: #4b55e8;
  border: 2rpx solid #dfe3ff;
}

.danger-btn {
  background: #fff1f1;
  color: #cf4a52;
  border: 2rpx solid #ffd6da;
}

.primary-btn::after,
.ghost-btn::after,
.danger-btn::after {
  border: none;
}

.muted-text {
  font-size: 22rpx;
  color: #92a0ac;
}
