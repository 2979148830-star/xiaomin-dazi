.chat-page {
  min-height: 100vh;
  padding: 24rpx 24rpx 150rpx;
  background: linear-gradient(180deg, #f4f6ff 0%, #f8fbff 48%, #eef8f5 100%);
  box-sizing: border-box;
}

.chat-hero {
  padding: 28rpx;
  border-radius: 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  background:
    radial-gradient(circle at 10% 0%, rgba(255, 255, 255, 0.72) 0%, rgba(255, 255, 255, 0) 30%),
    linear-gradient(135deg, #f0f4ff 0%, #fbf6ff 56%, #eefbf7 100%);
  box-shadow: 0 14rpx 32rpx rgba(79, 92, 170, 0.12);
  box-sizing: border-box;
}

.chat-title {
  color: #243140;
  font-size: 34rpx;
  line-height: 1.35;
  font-weight: 800;
}

.chat-desc {
  margin-top: 10rpx;
  color: #7a8492;
  font-size: 24rpx;
}

.deleted-tip {
  display: inline-flex;
  margin-top: 16rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #fff1f1;
  color: #cf4a52;
  font-size: 22rpx;
  font-weight: 700;
}

.message-list {
  height: calc(100vh - 340rpx);
  margin-top: 22rpx;
  box-sizing: border-box;
}

.empty-chat {
  margin-top: 160rpx;
  text-align: center;
  color: #9aa5b1;
  font-size: 26rpx;
}

.message-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.message-row.mine {
  justify-content: flex-end;
}

.message-row.peer {
  justify-content: flex-start;
}

.message-main {
  max-width: calc(100% - 94rpx);
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.message-row.mine .message-main {
  align-items: flex-end;
}

.message-row.peer .message-main {
  align-items: flex-start;
}

.message-avatar-wrap {
  width: 68rpx;
  height: 68rpx;
  flex-shrink: 0;
  margin-top: 38rpx;
}

.message-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background: #eef0ff;
  box-shadow: 0 8rpx 18rpx rgba(79, 92, 170, 0.12);
}

.message-avatar.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #4b55e8;
  font-size: 24rpx;
  font-weight: 800;
}

.message-name {
  max-width: 300rpx;
  margin-bottom: 7rpx;
  color: #8b95a3;
  font-size: 22rpx;
  line-height: 1.25;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.message-row.mine .message-name {
  text-align: right;
}

.message-bubble {
  max-width: 78%;
  padding: 18rpx 22rpx;
  border-radius: 22rpx;
  font-size: 28rpx;
  line-height: 1.55;
  word-break: break-word;
  box-sizing: border-box;
}

.message-main .message-bubble {
  max-width: 100%;
}

.message-row.mine .message-bubble {
  background: linear-gradient(135deg, #5f6bff 0%, #8b5cf6 100%);
  color: #ffffff;
  border-bottom-right-radius: 8rpx;
}

.message-row.peer .message-bubble {
  background: rgba(255, 255, 255, 0.76);
  color: #2f3850;
  border: 2rpx solid rgba(223, 227, 255, 0.7);
  border-bottom-left-radius: 8rpx;
}

.message-time {
  margin-top: 7rpx;
  color: #a0a8b3;
  font-size: 20rpx;
}

.input-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx 24rpx 28rpx;
  background:
    radial-gradient(circle at 12% 0%, rgba(255, 255, 255, 0.82) 0%, rgba(255, 255, 255, 0) 34%),
    linear-gradient(135deg, rgba(240, 244, 255, 0.98) 0%, rgba(251, 246, 255, 0.98) 56%, rgba(238, 251, 247, 0.98) 100%);
  box-shadow: 0 -6rpx 24rpx rgba(79, 92, 170, 0.12);
  box-sizing: border-box;
}

.message-input {
  flex: 1;
  min-width: 0;
  height: 78rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 2rpx solid rgba(223, 227, 255, 0.82);
  color: #243140;
  font-size: 27rpx;
  box-sizing: border-box;
}

.send-btn {
  width: 150rpx;
  height: 78rpx;
  margin: 0;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #5f6bff 0%, #8b5cf6 100%);
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
}

.send-btn::after {
  border: none;
}
