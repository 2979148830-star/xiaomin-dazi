.container {
  display: block;
  align-items: stretch;
  box-sizing: border-box;
  padding: 28rpx 28rpx 48rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, #f4f6ff 0%, #f8fbff 48%, #eef8f5 100%);
}

.user-header,
.note-section,
.contact-card,
.notify-card,
.info-card,
.joiners-card {
  margin-bottom: 24rpx;
}

.user-main,
.info-card,
.contact-card,
.notify-card,
.joiners-card {
  background:
    radial-gradient(circle at 10% 0%, rgba(255, 255, 255, 0.72) 0%, rgba(255, 255, 255, 0) 32%),
    linear-gradient(135deg, #f0f4ff 0%, #fbf6ff 56%, #eefbf7 100%);
  width: 100%;
  box-sizing: border-box;
  padding: 32rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 28rpx;
  box-shadow: 0 12rpx 30rpx rgba(79, 92, 170, 0.12);
}

.info-card {
  overflow: hidden;
}

.user-main {
  text-align: center;
}

.user-name {
  font-size: 42rpx;
  font-weight: bold;
  color: #27314b;
}

.user-tagline {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #5f6bff;
  font-weight: 600;
}

/* --- 标签组合容器 --- */
.user-tags-container {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 12rpx; /* 标签之间的间距 */
  margin-top: 20rpx;
}

/* --- 人设标签 (稳定靠谱搭) --- */
.tag-persona {
  display: inline-flex;
  align-items: center;
  /* 采用民大校徽紫色的非常浅的渐变色 */
  background: #eef4fb;
  color: #405f80;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: bold;
  margin-top: 8rpx;
  margin-bottom: 8rpx;
}

/* --- 性别标签 --- */
.tag-gender {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: bold;
}
.tag-gender .icon { margin-right: 4rpx; font-size: 20rpx; }
/* 男生：浅蓝底 深蓝字 */
.tag-gender.male { background-color: #E0F2FE; color: #0369A1; }
/* 女生：浅粉底 深粉字 */
.tag-gender.female { background-color: #FCE7F3; color: #BE185D; }
/* 保密：浅紫底 深紫字 */
.tag-gender.secret { background-color: #F3F4F6; color: #475569; }

/* --- 爱好标签 --- */
.tag-hobbies {
  display: inline-flex;
  align-items: center;
  background: #eef0ff;
  color: #4b55e8;
  padding: 4rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
  box-shadow: 0 2rpx 8rpx rgba(95, 107, 255, 0.07);
  max-width: 240rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.tag-hobbies .icon { margin-right: 6rpx; }

.tag-hobbies:nth-child(4n+1) {
  background: #eef0ff;
  color: #4b55e8;
}

.tag-hobbies:nth-child(4n+2) {
  background: #f0ebff;
  color: #7048d9;
}

.tag-hobbies:nth-child(4n+3) {
  background: #e7f8f6;
  color: #168a84;
}

.tag-hobbies:nth-child(4n+4) {
  background: #fff7e8;
  color: #9a6421;
}

/* --- 保留旧的样式用于 answer-tags --- */
.answer-tags {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 14rpx;
}

.answer-tag {
  display: inline-block;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #f3f4ff;
  color: #6059da;
}

.answer-tag:nth-child(4n+1) {
  background: #eef0ff;
  color: #4b55e8;
}

.answer-tag:nth-child(4n+2) {
  background: #f0ebff;
  color: #7048d9;
}

.answer-tag:nth-child(4n+3) {
  background: #e7f8f6;
  color: #168a84;
}

.answer-tag:nth-child(4n+4) {
  background: #fff7e8;
  color: #9a6421;
}

.card-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.card-title-main {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-title {
  flex: 0 1 auto;
  min-width: 0;
  font-size: 34rpx;
  font-weight: bold;
  color: #28304a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.full-banner {
  margin-bottom: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fff2f4;
  color: #e04d67;
  font-size: 24rpx;
  font-weight: 600;
}

.status-badge {
  min-height: 40rpx;
  box-sizing: border-box;
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  line-height: 1.2;
  font-weight: 700;
}

.status-badge.open {
  background: #eaf7f2;
  color: #1f8a5b;
}

.status-badge.full {
  background: #eff1f5;
  color: #9aa0b5;
}

.info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.grid-item {
  min-height: 118rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: center;
  background: rgba(255, 255, 255, 0.58);
  border: 2rpx solid rgba(223, 227, 255, 0.74);
  border-radius: 20rpx;
  padding: 20rpx 22rpx;
}

.label {
  display: block;
  font-size: 22rpx;
  color: #9399af;
  margin-bottom: 8rpx;
}

.value {
  display: block;
  font-size: 28rpx;
  color: #2d3450;
  line-height: 1.5;
}

.requirement-box {
  background: #eef7ff;
  border-radius: 20rpx;
  padding: 18rpx 20rpx;
}

.req-label {
  display: block;
  font-size: 22rpx;
  color: #7b89a5;
}

.req-value {
  display: block;
  margin-top: 6rpx;
  font-size: 28rpx;
  color: #3671c8;
  font-weight: bold;
}

.joiners-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.joiners-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #28304a;
}

.joiners-count {
  font-size: 22rpx;
  color: #69708a;
  background: #eef0ff;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
}

.joiners-list {
  display: flex;
  flex-wrap: wrap;
  gap: 22rpx 20rpx;
  padding: 4rpx 0 0;
}

.joiner-item {
  width: 112rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.joiner-item.chat-enabled {
  padding: 8rpx 6rpx;
  border-radius: 18rpx;
}

.joiner-item.chat-enabled:active {
  background: rgba(238, 240, 255, 0.72);
}

.joiner-avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #f3f4fb;
  border: 2rpx solid #ebedf5;
}

.joiner-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eef0ff;
  color: #4b55e8;
  font-size: 28rpx;
  font-weight: 700;
}

.joiner-name {
  width: 100%;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #69708a;
  text-align: center;
  line-height: 1.4;
}

.joiners-empty {
  font-size: 24rpx;
  color: #98a0b6;
  background: rgba(255, 255, 255, 0.58);
  border: 2rpx solid rgba(223, 227, 255, 0.74);
  border-radius: 20rpx;
  padding: 22rpx;
}

.note-section {
  margin-top: 20rpx;
  margin-bottom: 0;
  padding: 22rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.58);
  border: 2rpx solid rgba(223, 227, 255, 0.74);
  box-shadow: none;
}

.note-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.note-title {
  font-size: 24rpx;
  color: #4b55e8;
  font-weight: 800;
  letter-spacing: 0;
}

.note-dot {
  display: block;
  width: 36rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #8b5cf6 0%, rgba(139, 92, 246, 0) 100%);
  flex-shrink: 0;
}

.note-content {
  position: relative;
  font-size: 28rpx;
  color: #4f5a72;
  line-height: 1.7;
  padding-left: 20rpx;
  word-break: break-word;
}

.note-content::before {
  content: "";
  position: absolute;
  left: 0;
  top: 8rpx;
  bottom: 8rpx;
  width: 6rpx;
  border-radius: 999rpx;
  background: #5f6bff;
}

.manage-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.46);
  box-sizing: border-box;
}

.contact-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #28304a;
  margin-bottom: 16rpx;
}

.phone-line {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 70rpx;
  padding: 12rpx 14rpx 12rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(232, 249, 243, 0.72);
  border: 2rpx solid rgba(178, 232, 216, 0.56);
  box-sizing: border-box;
}

.phone-text {
  flex: 1;
  min-width: 0;
  color: #179777;
  font-size: 28rpx;
  line-height: 1.3;
  font-weight: bold;
  word-break: break-word;
}

.chat-inline-btn {
  flex-shrink: 0;
  width: 142rpx;
  height: 52rpx;
  line-height: 1.2;
  margin: 0;
  padding: 0 16rpx;
  border: none;
  border-radius: 999rpx;
  background: rgba(238, 240, 255, 0.92);
  color: #4b55e8;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  white-space: nowrap;
}

.chat-inline-btn::after {
  border: none;
}

.phone-locked {
  font-size: 24rpx;
  color: #8d94ab;
  background: rgba(255, 255, 255, 0.58);
  border: 2rpx solid rgba(223, 227, 255, 0.74);
  padding: 18rpx;
  border-radius: 20rpx;
}

.contact-actions {
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 2rpx solid rgba(223, 227, 255, 0.58);
}

.contact-action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  width: 100%;
  min-width: 0;
}

.contact-action-row.single {
  grid-template-columns: 1fr;
}

.contact-action-row .call-btn,
.contact-action-row .chat-btn,
.contact-action-row .leave-btn,
.contact-leave-btn {
  width: 100%;
  min-width: 0;
  height: 76rpx;
  padding: 0 12rpx;
  font-size: 26rpx;
}

.contact-leave-btn {
  margin-top: 16rpx;
}

.notify-card {
  background:
    radial-gradient(circle at 10% 0%, rgba(255, 255, 255, 0.72) 0%, rgba(255, 255, 255, 0) 32%),
    linear-gradient(135deg, #eef4ff 0%, #f4edff 54%, #e9f8f3 100%);
}

.notify-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #28304a;
  margin-bottom: 12rpx;
}

.notify-text {
  font-size: 24rpx;
  line-height: 1.6;
  color: #6d748e;
}

.notify-open-btn,
.notify-bottom-btn {
  width: 92%;
  height: 82rpx;
  margin: 22rpx auto 0;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #5f6bff, #8b5cf6);
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
}

.notify-open-btn::after,
.notify-bottom-btn::after {
  border: none;
}

.bottom-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  width: 100%;
  min-width: 0;
  margin-top: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 12% 0%, rgba(255, 255, 255, 0.82) 0%, rgba(255, 255, 255, 0) 34%),
    linear-gradient(135deg, rgba(240, 244, 255, 0.98) 0%, rgba(251, 246, 255, 0.98) 56%, rgba(238, 251, 247, 0.98) 100%);
  padding: 24rpx;
  box-shadow: 0 12rpx 30rpx rgba(79, 92, 170, 0.12);
  box-sizing: border-box;
}

.joined-actions {
  padding: 22rpx;
}

.action-row {
  display: flex;
  width: 100%;
  min-width: 0;
  gap: 16rpx;
}

.joined-action-row {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.call-btn,
.join-btn,
.notify-bottom-btn,
.chat-btn,
.edit-post-btn,
.leave-btn,
.delete-post-btn {
  height: 84rpx;
  line-height: 1.2;
  margin: 0;
  padding: 0 20rpx;
  border: none;
  border-radius: 999rpx;
  color: #fff;
  font-size: 28rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  white-space: nowrap;
}

.manage-actions .edit-post-btn,
.manage-actions .delete-post-btn {
  width: 100%;
  min-width: 0;
  height: 76rpx;
  padding: 0 12rpx;
  font-size: 26rpx;
  white-space: nowrap;
}

.join-btn,
.chat-btn,
.notify-bottom-btn {
  width: 100%;
}

.action-row .call-btn,
.action-row .edit-post-btn,
.action-row .leave-btn,
.action-row .delete-post-btn {
  flex: 1;
  width: 100%;
  min-width: 0;
}

.bottom-actions .action-row .call-btn,
.bottom-actions .action-row .leave-btn {
  width: 100%;
  height: 88rpx;
  font-size: 28rpx;
}

.call-btn {
  color: #35618f;
  background: linear-gradient(135deg, #eaf4ff 0%, #f0f7ff 100%);
  border: 2rpx solid #d7e7f8;
}

.join-btn {
  background: linear-gradient(90deg, #5f6bff, #8b5cf6);
  box-shadow: 0 12rpx 24rpx rgba(95, 107, 255, 0.18);
}

.chat-btn {
  color: #4b55e8;
  background: linear-gradient(135deg, #eef0ff 0%, #f0ebff 100%);
  border: 2rpx solid #dfe3ff;
}

.edit-post-btn {
  background: linear-gradient(90deg, #5f6bff, #8b5cf6);
}

.leave-btn {
  color: #56618f;
  background: linear-gradient(135deg, #eef0ff 0%, #f5f2ff 100%);
  border: 2rpx solid #dfe3ff;
}

.delete-post-btn {
  background: #fff1f1;
  color: #cf4a52;
}

.call-btn.disabled,
.join-btn.disabled {
  background: #d7dbe6;
  color: #fff;
}

.user-title-line {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  width: 100%;
  min-width: 0;
  white-space: nowrap;
}

.user-title-line .user-name {
  flex: 0 1 auto;
  min-width: 0;
  max-width: 390rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  text-align: center;
}

.user-title-line .tag-persona {
  flex-shrink: 0;
  margin: 0;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
}

.requirement-inline {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #eef7ff;
}

.title-requirement-inline {
  min-height: 42rpx;
  box-sizing: border-box;
  background: #eef0ff;
}

.req-inline-label {
  font-size: 19rpx;
  color: #7c8aa6;
}

.req-inline-value {
  font-size: 21rpx;
  color: #3671c8;
  font-weight: 700;
}

.requirement-box {
  display: none;
}
