.privacy-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f4f6ff 0%, #f8fbff 48%, #eef8f5 100%);
}

.privacy-content {
  padding: 40rpx;
  padding-bottom: 180rpx;
}

.header {
  text-align: center;
  margin-bottom: 50rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #243140;
  margin-bottom: 16rpx;
}

.version {
  font-size: 24rpx;
  color: #999;
}

.content-scroll {
  display: block;
  height: auto;
  max-height: none;
  margin-bottom: 40rpx;
  padding: 34rpx 32rpx 38rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 10% 0%, rgba(255, 255, 255, 0.72) 0%, rgba(255, 255, 255, 0) 30%),
    linear-gradient(135deg, #f0f4ff 0%, #fbf6ff 56%, #eefbf7 100%);
  box-shadow: 0 16rpx 36rpx rgba(79, 92, 170, 0.12);
  box-sizing: border-box;
  overflow: visible;
}

.section {
  margin-bottom: 40rpx;
}

.section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #5f6bff;
  margin-bottom: 20rpx;
  padding-left: 12rpx;
  border-left: 6rpx solid #5f6bff;
}

.text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

.item {
  margin: 16rpx 0;
  padding-left: 24rpx;
}

.footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background:
    radial-gradient(circle at 12% 0%, rgba(255, 255, 255, 0.82) 0%, rgba(255, 255, 255, 0) 34%),
    linear-gradient(135deg, rgba(240, 244, 255, 0.98) 0%, rgba(251, 246, 255, 0.98) 56%, rgba(238, 251, 247, 0.98) 100%);
  padding: 20rpx 40rpx;
  box-shadow: 0 -4rpx 20rpx rgba(79, 92, 170, 0.14);
}

.agree-btn {
  width: 100%;
  background: linear-gradient(135deg, #5f6bff 0%, #8b5cf6 100%);
  color: white;
  border-radius: 50rpx;
  font-weight: bold;
  padding: 28rpx;
  font-size: 32rpx;
  border: none;
}
