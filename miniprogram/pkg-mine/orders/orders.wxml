<view class="page-shell">
  <view class="section-card">
    <view class="section-kicker">搭子订单</view>
    <view class="section-title">我发布的和我加入的都在这里</view>
    <view class="section-desc">点进卡片就能进入帖子详情，已加入的帖子也可以直接联系。</view>

    <view class="summary-row">
      <view class="summary-pill {{activeTab === 'published' ? 'active' : ''}}">发布 {{publishedPosts.length}}</view>
      <view class="summary-pill {{activeTab === 'joined' ? 'active' : ''}}">加入 {{joinedPosts.length}}</view>
    </view>
  </view>

  <view class="tab-row">
    <view class="tab-pill {{activeTab === 'published' ? 'active' : ''}}" bindtap="switchTab" data-tab="published">
      我发布的
    </view>
    <view class="tab-pill {{activeTab === 'joined' ? 'active' : ''}}" bindtap="switchTab" data-tab="joined">
      我加入的
    </view>
  </view>

  <view class="section-card empty-card" wx:if="{{!currentList.length}}">
    <view class="empty-title">{{activeTab === 'published' ? '你还没有发布帖子' : '你还没有加入帖子'}}</view>
    <view class="empty-desc">
      {{activeTab === 'published' ? '去发一个新的搭子邀约吧。' : '去广场逛逛，也许马上就能找到合适的搭子。'}}
    </view>
    <button class="primary-btn" wx:if="{{activeTab === 'published'}}" bindtap="goPublish">去发布一个</button>
    <button class="ghost-btn" wx:else bindtap="goPlaza">去广场看看</button>
  </view>

  <view class="post-list" wx:if="{{currentList.length}}">
    <view class="section-card post-card" wx:for="{{currentList}}" wx:key="_id" bindtap="goDetail" data-id="{{item._id}}">
      <view class="post-head">
        <view class="post-type">#{{item.type}}</view>
        <text class="status-pill {{item.statusClass}}">{{item.statusText}}</text>
      </view>

      <view class="post-line">{{item.displayDate}} · {{item.time}}</view>
      <view class="post-line">{{item.location}}</view>
      <view class="post-line strong">{{item.remainText}}</view>

      <view class="post-note" wx:if="{{item.note}}">{{item.note}}</view>

      <view class="post-footer">
        <text class="footer-pill footer-meta">{{activeTab === 'published' ? ('已加入 ' + item.joinedCount + ' 人') : '点开可查看完整详情'}}</text>
        <text class="footer-pill phone-label" wx:if="{{activeTab === 'published' && item.phone}}">我的电话：{{item.phone}}</text>
        <button class="link-btn" wx:elif="{{item.phone}}" catchtap="callPhone" data-phone="{{item.phone}}">联系</button>
      </view>
    </view>
  </view>
</view>
