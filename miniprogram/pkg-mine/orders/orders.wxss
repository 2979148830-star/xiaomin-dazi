@import "../common.wxss";

.summary-row {
  display: flex;
  gap: 14rpx;
  margin-top: 24rpx;
}

.summary-pill {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.56);
  color: #61707f;
  font-size: 24rpx;
}

.summary-pill.active {
  background: #eef0ff;
  color: #4b55e8;
  font-weight: 600;
}

.tab-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.tab-pill {
  flex: 1;
  padding: 22rpx 0;
  text-align: center;
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.68);
  background: linear-gradient(135deg, rgba(240, 244, 255, 0.9) 0%, rgba(238, 251, 247, 0.9) 100%);
  color: #697684;
  font-size: 28rpx;
  box-shadow: 0 12rpx 26rpx rgba(79, 92, 170, 0.1);
  box-sizing: border-box;
}

.tab-pill.active {
  background: linear-gradient(135deg, #5f6bff 0%, #8b5cf6 100%);
  color: #ffffff;
  font-weight: 600;
}

.empty-card {
  text-align: center;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #243140;
}

.empty-desc {
  margin: 12rpx 0 24rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7d8995;
}

.post-card {
  margin-bottom: 20rpx;
}

.post-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.post-type {
  font-size: 30rpx;
  font-weight: 600;
  color: #243140;
}

.post-line {
  margin-top: 14rpx;
  font-size: 25rpx;
  line-height: 1.6;
  color: #647280;
}

.post-line.strong {
  color: #4b55e8;
  font-weight: 600;
}

.post-note {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.56);
  font-size: 24rpx;
  line-height: 1.6;
  color: #7a8692;
}

.post-footer {
  margin-top: 20rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 14rpx;
}

.footer-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(238, 240, 255, 0.82);
  border: 2rpx solid rgba(223, 227, 255, 0.92);
  font-size: 23rpx;
  line-height: 1;
  font-weight: 700;
  white-space: nowrap;
  box-sizing: border-box;
}

.footer-meta {
  flex: 0 0 auto;
  color: #7f8b99;
}

.phone-label {
  flex: 0 1 auto;
  min-width: 0;
  max-width: 420rpx;
  color: #4b55e8;
  overflow: hidden;
  text-overflow: ellipsis;
}

.link-btn {
  min-width: 120rpx;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: #eef0ff;
  color: #4b55e8;
  font-size: 24rpx;
  border: 2rpx solid #dfe3ff;
}

.link-btn::after {
  border: none;
}
