@import "../common.wxss";

.status-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.status-main {
  flex: 1;
  min-width: 0;
}

.guide-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #243140;
}

.guide-line {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #6f7c88;
}

.warning-card {
  background: rgba(255, 247, 240, 0.96);
}

.inline-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
}

.compact-btn {
  flex: 1;
  height: 76rpx;
  font-size: 26rpx;
  padding: 0 18rpx;
}

.inline-actions .ghost-btn {
  max-width: 150rpx;
}

.action-gap {
  margin-top: 16rpx;
}

.notice-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.notice-count {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eef0ff;
  color: #4b55e8;
  font-size: 22rpx;
  font-weight: 700;
}

.notice-empty {
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.56);
  color: #98a0ac;
  font-size: 24rpx;
  text-align: center;
}

.notice-item {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.56);
  border: 2rpx solid rgba(223, 227, 255, 0.68);
  box-sizing: border-box;
}

.notice-item.unread {
  background: rgba(238, 240, 255, 0.78);
  border-color: rgba(95, 107, 255, 0.18);
}

.notice-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.notice-title {
  flex: 1;
  min-width: 0;
  color: #243140;
  font-size: 26rpx;
  font-weight: 800;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.notice-time {
  flex-shrink: 0;
  color: #9aa5b1;
  font-size: 20rpx;
}

.notice-content {
  margin-top: 10rpx;
  color: #687482;
  font-size: 24rpx;
  line-height: 1.6;
}
