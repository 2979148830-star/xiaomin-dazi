@import "../common.wxss";

.profile-hero-top {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar-picker {
  width: 164rpx;
  height: 164rpx;
  min-width: 164rpx;
  max-width: 164rpx;
  border-radius: 40rpx;
  padding: 0;
  overflow: hidden;
  position: relative;
  background: #eef3f5;
  display: block;
  box-sizing: border-box;
  line-height: 0;
  box-shadow: 0 14rpx 32rpx rgba(36, 49, 64, 0.12);
  flex-shrink: 0;
}

.avatar-picker::after {
  border: none;
}

.avatar-stage {
  width: 100%;
  height: 100%;
  padding: 8rpx;
  box-sizing: border-box;
  background: #eef3f5;
}

.profile-avatar {
  width: 100%;
  height: 100%;
  border-radius: 30rpx;
}

.profile-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #eef0ff 0%, #e5e8ff 100%);
  color: #4b55e8;
  font-size: 52rpx;
  font-weight: 700;
}

.avatar-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 14rpx 0;
  background: rgba(36, 49, 64, 0.58);
  color: #ffffff;
  font-size: 22rpx;
  text-align: center;
}

.profile-hero-main {
  flex: 1;
  min-width: 0;
}

.profile-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #243140;
}

.profile-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #74808d;
}

.persona-strip {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.persona-pill {
  max-width: 100%;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.56);
  font-size: 22rpx;
  color: #566575;
}

.persona-pill.strong {
  background: #eef0ff;
  color: #4b55e8;
  font-weight: 600;
}

.field-label {
  font-size: 26rpx;
  color: #667482;
  margin-bottom: 14rpx;
}

.field-input,
.field-picker {
  width: 100%;
  min-height: 88rpx;
  border-radius: 22rpx;
  border: 2rpx solid rgba(223, 227, 255, 0.82);
  background: rgba(255, 255, 255, 0.58);
  box-sizing: border-box;
  padding: 24rpx;
  font-size: 28rpx;
  color: #243140;
}

.field-picker {
  display: flex;
  align-items: center;
  color: #99a5af;
}

.field-picker.selected {
  color: #243140;
}

.hobby-helper {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: rgba(255, 248, 237, 0.72);
}

.hobby-helper-title {
  font-size: 22rpx;
  color: #4b55e8;
  line-height: 1.5;
}

.hobby-preview {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.hobby-preview-chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #4b55e8;
  font-size: 22rpx;
  box-shadow: 0 6rpx 14rpx rgba(184, 101, 61, 0.08);
}

.hobby-preview-chip:nth-child(4n+1) {
  background: #eef0ff;
  color: #4b55e8;
}

.hobby-preview-chip:nth-child(4n+2) {
  background: #f0ebff;
  color: #7048d9;
}

.hobby-preview-chip:nth-child(4n+3) {
  background: #e7f8f6;
  color: #168a84;
}

.hobby-preview-chip:nth-child(4n+4) {
  background: #fff7e8;
  color: #9a6421;
}

.divider {
  height: 26rpx;
}

.tip-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #243140;
}

.tip-desc {
  margin-top: 10rpx;
  font-size: 28rpx;
  color: #4b55e8;
}

.tip-note {
  margin: 14rpx 0 22rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7b8793;
}

.save-btn {
  margin-top: 8rpx;
}
